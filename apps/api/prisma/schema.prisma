generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TPO_ADMIN
  COLLEGE_ADMIN
  RECRUITER
  COMPANY_ADMIN
  SUPER_ADMIN
}

enum PlacementStatus {
  NOT_STARTED
  PREPARING
  OPEN_TO_APPLY
  PLACED
  NOT_INTERESTED
}

enum JobType {
  INTERNSHIP
  FULL_TIME
  INTERNSHIP_PPO
}

enum DriveStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SHORTLISTED
  TEST_SCHEDULED
  TEST_COMPLETED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  WITHDRAWN
}

enum EligibilityStatus {
  ELIGIBLE
  NOT_ELIGIBLE
  PARTIALLY_READY
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(STUDENT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  studentProfile StudentProfile?
  createdDrives   Drive[]         @relation("DriveCreatedBy")
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@index([role])
}

model StudentProfile {
  id                  String          @id @default(cuid())
  userId              String          @unique
  phone               String?
  collegeName         String?
  branch              String?
  year                Int?
  graduationYear      Int?
  cgpa                Float?
  activeBacklogs      Int             @default(0)
  location            String?
  targetRole          String?
  preferredCompanies  String[]        @default([])
  preferredLocation   String?
  expectedSalary      Float?
  placementStatus     PlacementStatus @default(PREPARING)
  githubUsername      String?
  leetcodeUsername    String?
  hackerrankUsername  String?
  resumeUrl           String?
  readinessScore      Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills                  Skill[]
  projects                Project[]
  education               Education[]
  applications            Application[]
  readinessScoreHistories ReadinessScoreHistory[]
  codingProfileSnapshots  CodingProfileSnapshot[]
  githubProfile           GitHubProfile?
  leetcodeProfile         LeetCodeProfile?
  hackerRankProfile       HackerRankProfile?
  resumeAnalyses          ResumeAnalysis[]
  skillProofScores        SkillProofScore[]
  skillVerifications      SkillVerification[]
  jobMatchResults         JobMatchResult[]
  skillGaps               SkillGap[]
  roadmaps                StudentRoadmap[]

  @@index([branch])
  @@index([cgpa])
  @@index([activeBacklogs])
  @@index([placementStatus])
  @@index([readinessScore])
}

model Skill {
  id               String @id @default(cuid())
  studentProfileId String
  name             String
  category         String
  level            Int    @default(3)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([category])
}

model Project {
  id               String    @id @default(cuid())
  studentProfileId String
  title            String
  description      String
  techStack        String[]  @default([])
  githubUrl        String?
  liveUrl          String?
  category         String?
  startDate        DateTime?
  endDate          DateTime?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Education {
  id               String @id @default(cuid())
  studentProfileId String
  degree           String
  institute        String
  startYear        Int
  endYear          Int?
  score            String?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  industry    String?
  description String?
  createdAt   DateTime @default(now())

  drives Drive[]
}

model Drive {
  id                  String      @id @default(cuid())
  companyId           String
  createdById         String
  role                String
  description         String
  ctc                 Float?
  stipend             Float?
  location            String
  jobType             JobType
  eligibleBranches    String[]    @default([])
  minimumCgpa         Float       @default(0)
  maxBacklogs         Int         @default(0)
  requiredSkills      String[]    @default([])
  applicationDeadline DateTime
  testDate            DateTime?
  interviewDate       DateTime?
  status              DriveStatus @default(DRAFT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("DriveCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  applications Application[]
  jobDescriptionAnalysis JobDescriptionAnalysis?
  jobMatchResults        JobMatchResult[]
  skillGaps              SkillGap[]
  roadmaps               StudentRoadmap[]

  @@index([status])
  @@index([applicationDeadline])
  @@index([minimumCgpa])
  @@index([createdById])
  @@index([companyId])
}

model Application {
  id                String            @id @default(cuid())
  studentProfileId  String
  driveId           String
  status            ApplicationStatus @default(APPLIED)
  eligibilityStatus EligibilityStatus
  eligibilityReason String
  appliedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  drive          Drive          @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, driveId])
  @@index([studentProfileId])
  @@index([driveId])
  @@index([status])
  @@index([appliedAt])
}

model ReadinessScoreHistory {
  id               String   @id @default(cuid())
  studentProfileId String
  score            Int
  breakdownJson    Json
  suggestionsJson  Json
  createdAt        DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model CodingProfileSnapshot {
  id              String   @id @default(cuid())
  studentProfileId String
  platform        String
  username        String
  totalSolved     Int?
  ranking         String?
  publicStatsJson Json?
  lastSyncedAt    DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, platform])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([action])
}

model GitHubProfile {
  id               String   @id @default(cuid())
  studentProfileId String   @unique
  username         String
  name             String?
  bio              String?
  avatarUrl        String?
  profileUrl       String?
  publicRepos      Int      @default(0)
  followers        Int      @default(0)
  following        Int      @default(0)
  githubScore      Int      @default(0)
  strengthsJson    Json?
  weaknessesJson   Json?
  suggestionsJson  Json?
  rawDataJson      Json?
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile     @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  repositories   GitHubRepository[]

  @@index([username])
  @@index([githubScore])
}

model GitHubRepository {
  id              String   @id @default(cuid())
  githubProfileId String
  name            String
  description     String?
  url             String?
  primaryLanguage String?
  languagesJson   Json?
  stars           Int      @default(0)
  forks           Int      @default(0)
  openIssues      Int      @default(0)
  hasReadme       Boolean  @default(false)
  hasLiveDemo     Boolean  @default(false)
  topicsJson      Json?
  lastUpdatedAt   DateTime?
  qualityScore    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  githubProfile GitHubProfile @relation(fields: [githubProfileId], references: [id], onDelete: Cascade)

  @@index([githubProfileId])
  @@index([primaryLanguage])
  @@index([qualityScore])
}

model LeetCodeProfile {
  id              String   @id @default(cuid())
  studentProfileId String  @unique
  username        String
  profileUrl      String?
  totalSolved     Int      @default(0)
  easySolved      Int      @default(0)
  mediumSolved    Int      @default(0)
  hardSolved      Int      @default(0)
  ranking         Int?
  contestRating   Float?
  acceptanceRate  Float?
  badgesJson      Json?
  topicStatsJson  Json?
  leetcodeScore   Int      @default(0)
  strengthsJson   Json?
  weaknessesJson  Json?
  suggestionsJson Json?
  rawDataJson     Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([leetcodeScore])
}

model HackerRankProfile {
  id                  String   @id @default(cuid())
  studentProfileId    String   @unique
  username            String
  profileUrl          String?
  problemSolvingScore Int      @default(0)
  pythonScore         Int      @default(0)
  javaScore           Int      @default(0)
  sqlScore            Int      @default(0)
  certificationsJson  Json?
  testScoresJson      Json?
  hackerRankScore     Int      @default(0)
  strengthsJson       Json?
  weaknessesJson      Json?
  suggestionsJson     Json?
  rawDataJson         Json?
  lastSyncedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([hackerRankScore])
}

model ResumeAnalysis {
  id                  String   @id @default(cuid())
  studentProfileId    String
  resumeUrl           String?
  extractedText       String?
  detectedSkillsJson  Json?
  missingSectionsJson Json?
  weakPointsJson      Json?
  suggestionsJson     Json?
  atsScore            Int      @default(0)
  resumeScore         Int      @default(0)
  contactScore        Int      @default(0)
  educationScore      Int      @default(0)
  skillsScore         Int      @default(0)
  projectsScore       Int      @default(0)
  experienceScore     Int      @default(0)
  formattingScore     Int      @default(0)
  impactScore         Int      @default(0)
  linksScore          Int      @default(0)
  analyzedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@index([resumeScore])
  @@index([analyzedAt])
}

model JobDescriptionAnalysis {
  id                  String   @id @default(cuid())
  driveId             String   @unique
  extractedSkillsJson Json?
  requiredSkillsJson  Json?
  preferredSkillsJson Json?
  roleCategory        String?
  difficultyLevel     String?
  keywordsJson        Json?
  analysisJson        Json?
  analyzedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  drive Drive @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@index([difficultyLevel])
  @@index([roleCategory])
}

model SkillProofScore {
  id                       String   @id @default(cuid())
  studentProfileId         String
  overallScore             Int      @default(0)
  level                    String
  placementReadinessScore  Int      @default(0)
  resumeScore              Int      @default(0)
  githubScore              Int      @default(0)
  leetcodeScore            Int      @default(0)
  hackerRankScore          Int      @default(0)
  projectScore             Int      @default(0)
  skillVerificationScore   Int      @default(0)
  breakdownJson            Json?
  suggestionsJson          Json?
  calculatedAt             DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@index([overallScore])
  @@index([calculatedAt])
}

model SkillVerification {
  id               String   @id @default(cuid())
  studentProfileId String
  skillName        String
  proofLevel       String
  sourcesJson      Json?
  confidenceScore  Int      @default(0)
  suggestion       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, skillName])
  @@index([proofLevel])
}

model JobMatchResult {
  id                    String   @id @default(cuid())
  studentProfileId      String
  driveId               String
  matchScore            Int      @default(0)
  matchedSkillsJson     Json?
  missingSkillsJson     Json?
  weakSkillsJson        Json?
  strongProofSkillsJson Json?
  reasonsJson           Json?
  suggestionsJson       Json?
  calculatedAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  drive          Drive          @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, driveId])
  @@index([studentProfileId])
  @@index([driveId])
  @@index([matchScore])
}

model SkillGap {
  id               String   @id @default(cuid())
  studentProfileId String
  driveId          String
  skillName        String
  gapType          String
  priority         String
  recommendation   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  drive          Drive          @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@index([driveId])
  @@index([skillName])
  @@index([priority])
}

model StudentRoadmap {
  id               String   @id @default(cuid())
  studentProfileId String
  driveId          String?
  title            String
  durationDays     Int
  goal             String
  roadmapJson      Json?
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  drive          Drive?         @relation(fields: [driveId], references: [id], onDelete: SetNull)
  tasks          RoadmapTask[]

  @@index([studentProfileId])
  @@index([driveId])
  @@index([status])
}

model RoadmapTask {
  id          String   @id @default(cuid())
  roadmapId   String
  title       String
  description String?
  category    String
  priority    String
  dueDate     DateTime?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmap StudentRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([completed])
  @@index([category])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String
  website     String?
  logoUrl     String?
  industry    String?
  size        String?
  location    String?
  status      String   @default("active")
  description String?
  metadataJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([name])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role
  status         String   @default("active")
  departmentsJson Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
}

model TeamInvitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role
  token          String   @unique
  status         String   @default("pending")
  expiresAt      DateTime
  invitedById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([status])
}

model RecruiterProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  organizationId String
  fullName       String
  designation    String?
  phone          String?
  linkedinUrl    String?
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([verified])
}

model RecruiterJob {
  id                  String   @id @default(cuid())
  organizationId      String
  createdById         String
  title               String
  roleCategory        String?
  jobType             String
  workMode            String
  location            String
  ctc                 Float?
  stipend             Float?
  experienceLevel     String?
  description         String
  requiredSkillsJson  Json
  preferredSkillsJson Json?
  eligibilityJson     Json?
  minimumCgpa         Float    @default(0)
  allowedBranchesJson Json?
  maxBacklogs         Int      @default(0)
  hiringRoundsJson    Json?
  openings            Int      @default(1)
  deadline            DateTime
  visibility          String   @default("public")
  status              String   @default("draft")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([visibility])
  @@index([deadline])
}

model RecruiterApplication {
  id               String   @id @default(cuid())
  recruiterJobId   String
  studentProfileId String
  status           String   @default("applied")
  matchScore       Int      @default(0)
  source           String   @default("student")
  appliedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([recruiterJobId, studentProfileId])
  @@index([recruiterJobId])
  @@index([studentProfileId])
  @@index([status])
}

model CandidateView {
  id               String   @id @default(cuid())
  recruiterId      String
  studentProfileId String
  recruiterJobId   String?
  organizationId   String
  viewedAt         DateTime @default(now())

  @@index([recruiterId])
  @@index([studentProfileId])
  @@index([organizationId])
  @@index([viewedAt])
}

model CandidateShortlist {
  id               String   @id @default(cuid())
  recruiterJobId   String?
  studentProfileId String
  recruiterId      String
  organizationId   String
  status           String   @default("saved")
  rating           Int?
  notes            String?
  interviewDate    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([organizationId, recruiterJobId, studentProfileId])
  @@index([recruiterId])
  @@index([organizationId])
  @@index([status])
}

model ContactRequest {
  id               String   @id @default(cuid())
  recruiterId      String
  studentProfileId String
  organizationId   String
  recruiterJobId   String?
  status           String   @default("pending")
  message          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([recruiterId])
  @@index([studentProfileId])
  @@index([organizationId])
  @@index([status])
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  audience      String
  description   String?
  priceMonthly  Int      @default(0)
  priceYearly   Int      @default(0)
  currency      String   @default("INR")
  featuresJson  Json
  limitsJson    Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([audience])
  @@index([active])
}

model Subscription {
  id                      String   @id @default(cuid())
  organizationId          String?
  userId                  String?
  planId                  String
  status                  String   @default("trialing")
  billingCycle            String   @default("monthly")
  startDate               DateTime @default(now())
  endDate                 DateTime?
  trialEndsAt             DateTime?
  currentPeriodStart      DateTime @default(now())
  currentPeriodEnd        DateTime?
  razorpayCustomerId      String?
  razorpaySubscriptionId  String?
  cancelAtPeriodEnd       Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([planId])
  @@index([status])
}

model Payment {
  id                     String   @id @default(cuid())
  subscriptionId         String?
  organizationId         String?
  userId                 String?
  provider               String   @default("razorpay")
  providerPaymentId      String?
  providerOrderId        String?
  providerSubscriptionId String?
  amount                 Int
  currency               String   @default("INR")
  status                 String
  method                 String?
  paidAt                 DateTime?
  rawPayloadJson         Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([providerPaymentId])
  @@index([providerOrderId])
}

model Invoice {
  id             String   @id @default(cuid())
  subscriptionId String?
  organizationId String?
  paymentId      String?
  invoiceNumber  String   @unique
  amount         Int
  currency       String   @default("INR")
  status         String   @default("issued")
  invoiceUrl     String?
  issuedAt       DateTime @default(now())
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([paymentId])
  @@index([status])
}

model UsageRecord {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  featureKey     String
  count          Int      @default(1)
  periodStart    DateTime
  periodEnd      DateTime
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([featureKey])
  @@index([periodStart, periodEnd])
}

model FeatureLimit {
  id          String   @id @default(cuid())
  planId      String
  featureKey  String
  limitValue  Int
  period      String   @default("monthly")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model BillingCustomer {
  id                String   @id @default(cuid())
  organizationId    String?
  userId            String?
  provider          String   @default("razorpay")
  providerCustomerId String?
  email             String
  name              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([providerCustomerId])
}

model StudentVisibilitySetting {
  id                    String   @id @default(cuid())
  studentProfileId      String   @unique
  visibility            String   @default("private")
  allowRecruiterContact Boolean  @default(false)
  showEmail             Boolean  @default(false)
  showPhone             Boolean  @default(false)
  showResume            Boolean  @default(false)
  availabilityStatus    String   @default("available")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([visibility])
}

model AccountStatusLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  reason         String?
  performedById  String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
}
