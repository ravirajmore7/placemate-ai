generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TPO_ADMIN
  COLLEGE_ADMIN
  RECRUITER
  SUPER_ADMIN
}

enum PlacementStatus {
  NOT_STARTED
  PREPARING
  OPEN_TO_APPLY
  PLACED
  NOT_INTERESTED
}

enum JobType {
  INTERNSHIP
  FULL_TIME
  INTERNSHIP_PPO
}

enum DriveStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SHORTLISTED
  TEST_SCHEDULED
  TEST_COMPLETED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  WITHDRAWN
}

enum EligibilityStatus {
  ELIGIBLE
  NOT_ELIGIBLE
  PARTIALLY_READY
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(STUDENT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  studentProfile StudentProfile?
  createdDrives   Drive[]         @relation("DriveCreatedBy")
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@index([role])
}

model StudentProfile {
  id                  String          @id @default(cuid())
  userId              String          @unique
  phone               String?
  collegeName         String?
  branch              String?
  year                Int?
  graduationYear      Int?
  cgpa                Float?
  activeBacklogs      Int             @default(0)
  location            String?
  targetRole          String?
  preferredCompanies  String[]        @default([])
  preferredLocation   String?
  expectedSalary      Float?
  placementStatus     PlacementStatus @default(PREPARING)
  githubUsername      String?
  leetcodeUsername    String?
  hackerrankUsername  String?
  resumeUrl           String?
  readinessScore      Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills                  Skill[]
  projects                Project[]
  education               Education[]
  applications            Application[]
  readinessScoreHistories ReadinessScoreHistory[]
  codingProfileSnapshots  CodingProfileSnapshot[]

  @@index([branch])
  @@index([cgpa])
  @@index([readinessScore])
}

model Skill {
  id               String @id @default(cuid())
  studentProfileId String
  name             String
  category         String
  level            Int    @default(3)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([category])
}

model Project {
  id               String    @id @default(cuid())
  studentProfileId String
  title            String
  description      String
  techStack        String[]  @default([])
  githubUrl        String?
  liveUrl          String?
  category         String?
  startDate        DateTime?
  endDate          DateTime?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Education {
  id               String @id @default(cuid())
  studentProfileId String
  degree           String
  institute        String
  startYear        Int
  endYear          Int?
  score            String?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  industry    String?
  description String?
  createdAt   DateTime @default(now())

  drives Drive[]
}

model Drive {
  id                  String      @id @default(cuid())
  companyId           String
  createdById         String
  role                String
  description         String
  ctc                 Float?
  stipend             Float?
  location            String
  jobType             JobType
  eligibleBranches    String[]    @default([])
  minimumCgpa         Float       @default(0)
  maxBacklogs         Int         @default(0)
  requiredSkills      String[]    @default([])
  applicationDeadline DateTime
  testDate            DateTime?
  interviewDate       DateTime?
  status              DriveStatus @default(DRAFT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("DriveCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  applications Application[]

  @@index([status])
  @@index([applicationDeadline])
}

model Application {
  id                String            @id @default(cuid())
  studentProfileId  String
  driveId           String
  status            ApplicationStatus @default(APPLIED)
  eligibilityStatus EligibilityStatus
  eligibilityReason String
  appliedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  drive          Drive          @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, driveId])
  @@index([status])
}

model ReadinessScoreHistory {
  id               String   @id @default(cuid())
  studentProfileId String
  score            Int
  breakdownJson    Json
  suggestionsJson  Json
  createdAt        DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model CodingProfileSnapshot {
  id              String   @id @default(cuid())
  studentProfileId String
  platform        String
  username        String
  totalSolved     Int?
  ranking         String?
  publicStatsJson Json?
  lastSyncedAt    DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, platform])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([action])
}
